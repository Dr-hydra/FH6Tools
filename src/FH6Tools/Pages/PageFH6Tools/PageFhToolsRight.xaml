<local:MyPageRight x:Class="PageFhToolsRight"
                   xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                   xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                   xmlns:local="clr-namespace:FH6Tools"
                   xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
                   PanScroll="PanBack">
    <local:MyScrollViewer x:Name="PanBack" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" SizeChanged="GuideLayout_SizeChanged">
        <StackPanel x:Name="PanRightContent" Margin="28,24,28,14">
            <StackPanel x:Name="PanHome">
                <TextBlock x:Name="LabInstalledToolSummary" Text="正在加载已安装工具..." Foreground="{DynamicResource ColorBrushGray3}" Margin="0,0,0,12" />
                <ItemsControl x:Name="InstalledToolCards">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <local:MyCard Title="{Binding DisplayName}" Margin="0,0,0,10">
                                <StackPanel Margin="18,46,18,18">
                                    <TextBlock Text="{Binding RuntimeSummaryLine}" Foreground="{DynamicResource ColorBrushGray3}" TextTrimming="CharacterEllipsis" />
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,6,12,0">
                                    <TextBlock Text="{Binding RuntimeStateText}" VerticalAlignment="Center" Foreground="{DynamicResource ColorBrushGray3}" Margin="0,0,10,0" />
                                    <local:MyCheckBox Text="随游戏启动" Checked="{Binding LaunchWithGame}" Change="ToolLaunchWithGame_Change" Margin="0,0,10,0" />
                                    <local:MyCheckBox Text="管理员启动" Checked="{Binding RunAsAdministrator}" Change="ToolRunAsAdministrator_Change" Margin="0,0,10,0" />
                                    <local:MyButton Text="{Binding BackendText}" Visibility="{Binding BackendVisibility}" Padding="9,5" Margin="0,0,6,0" Click="ToolStartBackend_Click" />
                                    <local:MyButton Text="{Binding FrontendText}" Visibility="{Binding BackendVisibility}" Padding="9,5" Margin="0,0,6,0" Click="ToolOpenFrontend_Click" />
                                    <local:MyButton Text="{Binding StartText}" Padding="9,5" ColorType="Highlight" Margin="0,0,6,0" Click="ToolStartAll_Click" />
                                    <local:MyButton Text="{Binding StopText}" Padding="9,5" ColorType="Red" Click="ToolStop_Click" />
                                </StackPanel>
                            </local:MyCard>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>

            <Grid x:Name="PanGuide" Visibility="Collapsed">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition MinWidth="300" />
                    <ColumnDefinition Width="18" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Border Grid.Column="0" ClipToBounds="True" Background="#F7000000" CornerRadius="6">
                    <local:MyScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                        <local:MyImage x:Name="ImgGuideSheet" Stretch="UniformToFill" RenderOptions.BitmapScalingMode="HighQuality" />
                    </local:MyScrollViewer>
                </Border>
                <Border Grid.Column="2" x:Name="GuideWebFrame" Width="390" MinWidth="320" MaxWidth="520" ClipToBounds="True" Background="White" CornerRadius="6" BorderBrush="{DynamicResource ColorBrush1}" BorderThickness="1" SizeChanged="GuideWebFrame_SizeChanged">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="36" />
                            <RowDefinition />
                        </Grid.RowDefinitions>
                        <Border Background="#F9FFFFFF" BorderBrush="{DynamicResource ColorBrush1}" BorderThickness="0,0,0,1">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                                <local:MyIconButton x:Name="BtnGuideWebBack" ToolTip="返回" Width="27" Height="27" Margin="0,0,8,0" LogoScale="0.78" Logo="M704 192 384 512l320 320-96 96L192 512 608 96z" Click="BtnGuideWebBack_Click" />
                                <local:MyIconButton x:Name="BtnGuideWebForward" ToolTip="前进" Width="27" Height="27" Margin="0,0,8,0" LogoScale="0.78" Logo="M320 192 640 512 320 832l96 96L832 512 416 96z" Click="BtnGuideWebForward_Click" />
                                <local:MyIconButton x:Name="BtnGuideWebRefresh" ToolTip="刷新" Width="27" Height="27" Margin="0,0,8,0" LogoScale="0.78" Logo="M832 256v224H608l84-84A256 256 0 1 0 768 576h128a384 384 0 1 1-112-272L832 256z" Click="BtnGuideWebRefresh_Click" />
                                <local:MyIconButton x:Name="BtnGuideWebHome" ToolTip="回到攻略链接" Width="27" Height="27" Margin="0,0,8,0" LogoScale="0.78" Logo="M512 128 128 448h96v384h224V608h128v224h224V448h96z" Click="BtnGuideWebHome_Click" />
                                <local:MyIconButton x:Name="BtnGuideWebOpenExternal" ToolTip="在浏览器打开" Width="27" Height="27" LogoScale="0.78" Logo="M192 192h320v96H288v448h448V512h96v320H192zM608 128h288v288h-96V292L480 612l-68-68 320-320H608z" Click="BtnGuideWebOpenExternal_Click" />
                            </StackPanel>
                        </Border>
                        <wv2:WebView2 Grid.Row="1" x:Name="GuideWebView" DefaultBackgroundColor="White" />
                        <TextBlock Grid.Row="1" x:Name="LabGuideWebStatus" Text="正在加载攻略网页..." TextWrapping="Wrap" HorizontalAlignment="Center" VerticalAlignment="Center" TextAlignment="Center" Foreground="{DynamicResource ColorBrushGray3}" Margin="18" />
                    </Grid>
                </Border>
            </Grid>

            <StackPanel x:Name="PanInstalledTools" Visibility="Collapsed">
                <TextBlock x:Name="LabConfigToolSummary" Text="正在加载已安装工具..." Foreground="{DynamicResource ColorBrushGray3}" Margin="0,0,0,12" />
                <ItemsControl x:Name="ConfigToolCards">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <local:MyCard Title="{Binding DisplayName}" Margin="0,0,0,10" CanSwap="True" IsSwaped="True" Loaded="ConfigToolCard_Loaded" Swap="ConfigToolCard_Swap">
                                <StackPanel x:Name="ConfigToolCardContent" Margin="18,46,18,18">
                                    <TextBlock Text="{Binding InstallLocationLine}" Foreground="{DynamicResource ColorBrushGray3}" TextWrapping="Wrap" Margin="0,0,0,8" />
                                    <TextBlock Text="{Binding InstalledVersionLine}" Foreground="{DynamicResource ColorBrushGray3}" TextWrapping="Wrap" Margin="0,0,0,8" />
                                    <TextBlock Text="{Binding InstallTimeLine}" Foreground="{DynamicResource ColorBrushGray3}" TextWrapping="Wrap" />
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,6,38,0">
                                    <local:MyIconTextButton Text="{Binding RenameText}" Visibility="{Binding BindButtonVisibility}" Height="27" Margin="0,0,6,0" LogoScale="0.7" Logo="M256 768h128l384-384-128-128-384 384v128zM896 128l-64 64-128-128 64-64c12-12 32-12 44 0l84 84c12 12 12 32 0 44z" Click="HeaderToolRename_Click" />
                                    <local:MyIconTextButton Text="{Binding BindText}" Visibility="{Binding BindButtonVisibility}" Height="27" Margin="0,0,6,0" LogoScale="0.7" Logo="M512 320a192 192 0 1 0 0 384 192 192 0 0 0 0-384zM448 64h128l24 112 96 40 96-64 80 80-64 96 40 96 112 24v128l-112 24-40 96 64 96-80 80-96-64-96 40-24 112H448l-24-112-96-40-96 64-80-80 64-96-40-96-112-24V448l112-24 40-96-64-96 80-80 96 64 96-40z" Click="HeaderToolBind_Click" />
                                    <local:MyIconTextButton Text="{Binding OpenFolderText}" Height="27" Margin="0,0,6,0" LogoScale="0.7" Logo="M96 256h320l96 96h416v448H96z" Click="HeaderToolOpenFolder_Click" />
                                    <local:MyIconTextButton Text="{Binding UninstallText}" Height="27" LogoScale="0.7" Logo="F1 M2,0 L0,2 8,10 0,18 2,20 10,12 18,20 20,18 12,10 20,2 18,0 10,8 2,0Z" Click="HeaderToolUninstall_Click" />
                                </StackPanel>
                            </local:MyCard>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>

            <local:MyCard x:Name="CardDownloads" Title="下载管理" Visibility="Collapsed">
                <StackPanel Margin="20,42,20,18">
                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition /><ColumnDefinition Width="8" /><ColumnDefinition />
                            <ColumnDefinition Width="8" /><ColumnDefinition /><ColumnDefinition Width="8" /><ColumnDefinition />
                        </Grid.ColumnDefinitions>
                        <local:MyButton x:Name="BtnReloadManifest" Text="检查更新" Padding="10,8" />
                        <local:MyButton x:Name="BtnChangeInstallRoot" Grid.Column="2" Text="更改安装位置" Padding="10,8" />
                        <local:MyButton x:Name="BtnImportZip" Grid.Column="4" Text="导入 ZIP" Padding="10,8" />
                        <local:MyButton x:Name="BtnImportFolder" Grid.Column="6" Text="添加文件夹" Padding="10,8" />
                    </Grid>
                    <TextBlock x:Name="LabDownloadStatus" Text="当前没有下载任务。" TextWrapping="Wrap" Foreground="{DynamicResource ColorBrushGray3}" Margin="0,0,0,8" />
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition />
                            <ColumnDefinition Width="10" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <ProgressBar x:Name="DownloadProgressBar" Height="8" Minimum="0" Maximum="100" Value="0" VerticalAlignment="Center" />
                        <local:MyButton x:Name="BtnCancelDownload" Grid.Column="2" Text="取消安装" Padding="12,5" Margin="0" Click="BtnCancelDownload_Click" />
                    </Grid>
                </StackPanel>
            </local:MyCard>
            <ItemsControl x:Name="DownloadToolCards" Visibility="Collapsed" Margin="0,12,0,0">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <local:MyCard Title="{Binding DisplayName}" Margin="0,0,0,10">
                            <StackPanel Margin="18,46,18,18">
                                <TextBlock Text="{Binding DownloadDetailLine}" TextTrimming="CharacterEllipsis" Foreground="{DynamicResource ColorBrushGray3}" />
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,6,38,0">
                                <TextBlock Text="{Binding DownloadStateText}" Foreground="{Binding DownloadStateBrush}" FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,8,0" />
                                <local:MyIconButton ToolTip="下载或更新" Width="26" Height="26" LogoScale="0.72" Logo="M448 96h128v480l160-160 96 96-320 320-320-320 96-96 160 160z" Click="IconToolInstall_Click" />
                                <local:MyIconButton ToolTip="访问项目" Width="26" Height="26" LogoScale="0.72" Logo="M512 64a448 448 0 0 0-142 873c22 4 30-10 30-22v-78c-124 27-150-53-150-53-20-52-50-66-50-66-41-28 3-27 3-27 45 3 69 46 69 46 40 68 105 48 131 37 4-29 16-48 29-59-99-11-203-49-203-221 0-49 17-89 46-120-5-11-20-57 4-118 0 0 38-12 123 46a426 426 0 0 1 224 0c85-58 123-46 123-46 24 61 9 107 4 118 29 31 46 71 46 120 0 172-104 210-203 221 16 14 30 41 30 82v122c0 12 8 26 30 22A448 448 0 0 0 512 64z" Click="ToolOpenProject_Click" />
                            </StackPanel>
                        </local:MyCard>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <local:MyCard x:Name="CardConfig" Title="配置管理" Visibility="Collapsed">
                <StackPanel Margin="20,42,20,18">
                    <TextBlock x:Name="LabLanguageTitle" Text="界面语言" FontWeight="SemiBold" Margin="0,0,0,6" />
                    <TextBlock x:Name="LabLanguageHint" Text="默认使用简体中文，切换后立即生效。" TextWrapping="Wrap" Foreground="{DynamicResource ColorBrushGray3}" Margin="0,0,0,8" />
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,18">
                        <local:MyRadioBox x:Name="RadioLanguageZh" Text="简体中文" Tag="zh-CN" Checked="True" Margin="0,0,18,0" />
                        <local:MyRadioBox x:Name="RadioLanguageEn" Text="English" Tag="en-US" />
                    </StackPanel>
                    <TextBlock Text="开机自启动" FontWeight="SemiBold" Margin="0,0,0,8" />
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,18">
                        <local:MyRadioBox x:Name="RadioStartupOn" Text="启用" Tag="on" Margin="0,0,18,0" />
                        <local:MyRadioBox x:Name="RadioStartupOff" Text="关闭" Tag="off" Checked="True" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <local:MyButton x:Name="BtnOpenAppRoot" Text="打开软件目录" Padding="14,7" Margin="0,0,8,0" />
                        <local:MyButton x:Name="BtnOpenDataRoot" Text="打开数据目录" Padding="14,7" />
                    </StackPanel>
                </StackPanel>
            </local:MyCard>

            <local:MyCard x:Name="CardGameData" Title="游戏与数据" Visibility="Collapsed">
                <StackPanel Margin="20,42,20,18">
                    <TextBlock x:Name="LabGameVersionTitle" Text="游戏版本" FontWeight="SemiBold" Margin="0,0,0,6" />
                    <TextBlock x:Name="LabGameVersionHint" Text="自动检测失败时，可以手动指定已安装版本。" TextWrapping="Wrap" Foreground="{DynamicResource ColorBrushGray3}" Margin="0,0,0,8" />
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                        <local:MyRadioBox x:Name="RadioGameAuto" Text="自动检测" Tag="Auto" Checked="True" Margin="0,0,18,0" />
                        <local:MyRadioBox x:Name="RadioGameXbox" Text="Xbox" Tag="Xbox" Margin="0,0,18,0" />
                        <local:MyRadioBox x:Name="RadioGameSteam" Text="Steam" Tag="Steam" />
                    </StackPanel>
                    <TextBlock x:Name="LabManualGamePath" Text="手动路径：未设置" TextWrapping="Wrap" Foreground="{DynamicResource ColorBrushGray3}" Margin="0,0,0,10" />
                    <TextBlock x:Name="LabGameSavePath" Text="存档路径：正在识别..." TextWrapping="Wrap" Foreground="{DynamicResource ColorBrushGray3}" Margin="0,0,0,10" />
                    <TextBlock x:Name="LabGameDetectionStatus" Text="正在检测游戏..." Foreground="{DynamicResource ColorBrushGray3}" TextWrapping="Wrap" Margin="0,0,0,14" />
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition />
                            <ColumnDefinition Width="8" />
                            <ColumnDefinition />
                            <ColumnDefinition Width="8" />
                            <ColumnDefinition />
                            <ColumnDefinition Width="8" />
                            <ColumnDefinition />
                        </Grid.ColumnDefinitions>
                        <local:MyButton x:Name="BtnBindGame" Text="指定游戏路径" Padding="12,8" />
                        <local:MyButton x:Name="BtnRefreshGame" Grid.Column="2" Text="重新检测游戏" Padding="12,8" />
                        <local:MyButton x:Name="BtnOpenGameFolder" Grid.Column="4" Text="打开游戏目录" Padding="12,8" />
                        <local:MyButton x:Name="BtnClearGameOverride" Grid.Column="6" Text="清除手动设置" Padding="12,8" />
                    </Grid>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition />
                            <ColumnDefinition Width="8" />
                            <ColumnDefinition />
                        </Grid.ColumnDefinitions>
                        <local:MyButton x:Name="BtnSetGameSavePath" Text="自定义存档路径" Padding="12,8" />
                        <local:MyButton x:Name="BtnClearGameSavePath" Grid.Column="2" Text="恢复自动识别" Padding="12,8" />
                    </Grid>
                </StackPanel>
            </local:MyCard>

            <local:MyCard x:Name="CardAbout" Title="关于 FH6Tools" Visibility="Collapsed">
                <StackPanel Margin="20,42,20,18">
                    <TextBlock x:Name="LabAboutDescription" Text="FH6Tools 是用于启动地平线 6 和管理社区工具的本地 Windows 工具中心。" TextWrapping="Wrap" Foreground="{DynamicResource ColorBrush2}" Margin="0,0,0,12" />
                    <local:MyListItem x:Name="ItemAboutManifest" Title="工具清单" Info="远程清单可以新增工具，并同步项目地址、名称和中英简介。" IsHitTestVisible="False" Height="54" />
                    <local:MyListItem x:Name="ItemAboutMigration" Title="Xbox 存档路径" Info="Xbox 版根据游戏目录识别同一安装根目录下的 GameSave\pgs，也可以在设置中单独指定。" IsHitTestVisible="False" Height="54" Margin="0,8,0,0" />
                    <TextBlock x:Name="LabUiCredit" TextWrapping="Wrap" Foreground="{DynamicResource ColorBrushGray3}" Margin="0,8,0,0">
                        <Run Text="本项目的 UI 设计借鉴了 " />
                        <Hyperlink NavigateUri="https://github.com/Meloong-Git/PCL" RequestNavigate="UiCredit_RequestNavigate">Meloong-Git/PCL</Hyperlink>
                        <Run Text="。" />
                    </TextBlock>
                    <TextBlock x:Name="LabProjectAddress" TextWrapping="Wrap" Foreground="{DynamicResource ColorBrushGray3}" Margin="0,8,0,0">
                        <Run Text="项目地址：" />
                        <Hyperlink NavigateUri="https://github.com/Dr-hydra/FH6Tools" RequestNavigate="ProjectAddress_RequestNavigate">Dr-hydra/FH6Tools</Hyperlink>
                    </TextBlock>
                    <local:MyListItem x:Name="ItemAboutUpdateProtection" Title="更新数据保护" Info="软件更新只覆盖程序文件，会保留配置、存档备份和已安装工具。" IsHitTestVisible="False" Height="54" Margin="0,8,0,0" />
                    <TextBlock x:Name="LabAppUpdateStatus" Text="尚未检查软件更新。" TextWrapping="Wrap" Foreground="{DynamicResource ColorBrushGray3}" Margin="0,10,0,0" />
                    <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                        <local:MyButton x:Name="BtnCheckAppUpdate" Text="检查更新" Padding="14,7" />
                    </StackPanel>
                </StackPanel>
            </local:MyCard>

            <local:MyCard x:Name="CardRuntimeInfo" Title="运行时与安全" Visibility="Collapsed">
                <StackPanel Margin="20,42,20,18">
                    <local:MyListItem x:Name="ItemAboutSafety" Title="安全策略" Info="违反项目安全策略的条目不会被安装或启动。" IsHitTestVisible="False" Height="54" />
                    <local:MyListItem x:Name="ItemAboutRuntime" Title="共享运行时" Info=".NET 10 Desktop 与 ASP.NET Core Runtime 由所有托管程序共享。" IsHitTestVisible="False" Height="54" />
                </StackPanel>
            </local:MyCard>
        </StackPanel>
    </local:MyScrollViewer>
</local:MyPageRight>
