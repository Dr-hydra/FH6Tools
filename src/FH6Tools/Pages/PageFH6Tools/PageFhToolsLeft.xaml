<local:MyPageLeft x:Class="PageFhToolsLeft"
                  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                  xmlns:local="clr-namespace:FH6Tools"
                  AnimatedControl="PanAnimated"
                  Width="190">
    <Grid x:Name="PanAnimated" Background="#FAFFFFFF">
        <StackPanel x:Name="PanLauncher" Margin="18,28,18,18">
            <Border Width="104" Height="104" CornerRadius="20" HorizontalAlignment="Center" Margin="0,0,0,18">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="{DynamicResource ColorObject3}" Offset="0" />
                        <GradientStop Color="{DynamicResource ColorObject1}" Offset="1" />
                    </LinearGradientBrush>
                </Border.Background>
                <TextBlock Text="FH6" Foreground="White" FontSize="31" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center" />
            </Border>
            <TextBlock x:Name="LabGamePlatform" Text="未检测到游戏" TextAlignment="Center" TextWrapping="Wrap" Foreground="{DynamicResource ColorBrushGray3}" Margin="0,0,0,14" />
            <local:MyButton x:Name="BtnLaunchGame" Text="启动地平线 6" Padding="12,9" ColorType="Highlight" HorizontalAlignment="Stretch" Margin="0,0,0,8" />
            <local:MyButton x:Name="BtnOpenGameBackups" Text="查看存档备份" Padding="12,8" HorizontalAlignment="Stretch" />
        </StackPanel>

        <StackPanel x:Name="PanNavigation" Margin="0,16,0,0" Visibility="Collapsed">
            <local:MyListItem x:Name="ItemTools" Title="已安装工具" Type="RadioBox" Tag="1" Height="38" PaddingLeft="4" IsScaleAnimationEnabled="False" />
            <local:MyListItem x:Name="ItemDownloads" Title="下载" Type="RadioBox" Tag="2" Height="38" PaddingLeft="4" IsScaleAnimationEnabled="False" />
            <local:MyListItem x:Name="ItemConfig" Title="常规设置" Type="RadioBox" Tag="3" Height="38" PaddingLeft="4" IsScaleAnimationEnabled="False" />
            <local:MyListItem x:Name="ItemGameData" Title="游戏与数据" Type="RadioBox" Tag="5" Height="38" PaddingLeft="4" IsScaleAnimationEnabled="False" />
            <local:MyListItem x:Name="ItemAbout" Title="关于 FH6Tools" Type="RadioBox" Tag="4" Height="38" PaddingLeft="4" IsScaleAnimationEnabled="False" />
            <local:MyListItem x:Name="ItemRuntimeInfo" Title="运行时与安全" Type="RadioBox" Tag="6" Height="38" PaddingLeft="4" IsScaleAnimationEnabled="False" />
        </StackPanel>
    </Grid>
</local:MyPageLeft>
