    {
      "id": "horizon-haptics",
      "name": "HorizonHaptics",
      "version": "latest",
      "category": "controller",
      "description": "DualSense adaptive trigger and haptics bridge for FH6 Data Out telemetry.",
      "descriptionZh": "通过 FH6 Data Out 遥测为 DualSense 控制器提供自适应扳机与触觉反馈。",
      "homepage": "https://github.com/haritha99ch/HorizonHaptics",
      "downloadUrl": "github-release://haritha99ch/HorizonHaptics/*.zip",
      "sha256": "",
      "installType": "zip",
      "toolType": "single",
      "single": {
        "executable": "%SystemRoot%\\System32\\cmd.exe",
        "workingDirectory": "{toolRoot}",
        "defaultPort": 0,
        "healthUrl": "",
        "url": "",
        "arguments": [
          "/c",
          "run.bat"
        ],
        "environmentVariables": {
          "USERPROFILE": "{toolRoot}\\profile",
          "APPDATA": "{toolRoot}\\profile\\AppData\\Roaming",
          "XDG_CONFIG_HOME": "{toolRoot}\\profile\\.config",
          "UV_CACHE_DIR": "{toolRoot}\\.uv-cache"
        }
      },
      "configFiles": [
        {
          "name": "Settings",
          "path": "profile\\.config\\horizonhaptics\\settings.json",
          "kind": "file"
        }
      ],
      "telemetryPort": 5300,
      "requiresAdmin": false,
      "riskLevel": "normal",
      "notes": "Receives FH6 UDP telemetry on port 5300; first run may need firewall approval."
    },
